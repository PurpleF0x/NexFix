<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Nex" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#7C3AED</item>
        <item name="colorPrimaryVariant">#4C1D95</item>
        <item name="colorOnPrimary">#E9D5FF</item>
        <item name="colorSecondary">#A78BFA</item>
        <item name="colorSurface">#0A0A0F</item>
        <item name="android:colorBackground">#0A0A0F</item>
        <item name="android:windowBackground">#0A0A0F</item>
        <item name="android:statusBarColor">#0A0A0F</item>
        <item name="android:navigationBarColor">#0A0A0F</item>
        <item name="android:windowLightStatusBar">false</item>
